# Discord Configuration
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CHANNEL_ID=123456789012345678

# Groq AI Configuration (for sentiment analysis)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Nitter Configuration
# Comma-separated list of Nitter instances (tried in order)
NITTER_INSTANCES=nitter.net,nitter.privacydev.com,nitter.fdn.fr
NITTER_USERNAME=aleabitoreddit

# RSS-Bridge Configuration (optional secondary source)
# Set to a RSS-Bridge instance URL (e.g., https://your-rssbridge-instance.com)
# Leave empty to disable RSS-Bridge fallback
RSS_BRIDGE_URL=

# Twitter API Configuration (optional emergency fallback)
# Only used as last resort when Nitter and RSS-Bridge both fail
# Requires Twitter API Basic tier ($5/mo for 10,000 tweets / $0.50 per 1,000 tweets)
TWITTER_BEARER_TOKEN=

# Ticker Filtering (optional)
# Only analyze tweets containing these tickers. Leave empty to analyze all.
# Example: TICKER_FILTERS=BTC,ETH,SOL
TICKER_FILTERS=

# Features
SENTIMENT_ENABLED=true
FLIP_ALERTS_ENABLED=true

# Storage
# On Railway, use /data for persistent storage
LAST_TWEET_FILE=/data/last_tweet_id.txt
DB_PATH=/data/sentiment.db

# Railway-specific (optional)
RAILWAY_ENVIRONMENT=production
